[[headers]]
  for = "/manifest.webmanifest"
  [headers.values]
    Access-Control-Allow-Origin = "*"
    Content-Type = "application/manifest+json"

[[headers]]
  for = "/sw.js"
  [headers.values]
    Access-Control-Allow-Origin = "*"

[[headers]]
  for = "/*.png"
  [headers.values]
    Access-Control-Allow-Origin = "*"
